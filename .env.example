# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/resumetric

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ─── ML Service ───────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ─── CORS ─────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Email / SMTP (for OTP) ───────────────────────────────
# Gmail: enable 2FA → https://myaccount.google.com/apppasswords → create App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
MAIL_FROM="Resumetric <your_gmail@gmail.com>"
